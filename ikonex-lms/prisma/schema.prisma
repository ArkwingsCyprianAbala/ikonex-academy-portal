generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClassStream {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students       Student[]
  streamSubjects StreamSubject[]
}

model Student {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  studentNumber String   @unique
  gender        Gender
  dateOfBirth   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  classStreamId String
  classStream   ClassStream @relation(fields: [classStreamId], references: [id])

  scores  Score[]
  results Result[]
}

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  streamSubjects StreamSubject[]
  scores         Score[]
}

model StreamSubject {
  id        String @id @default(cuid())
  streamId  String
  subjectId String

  classStream ClassStream @relation(fields: [streamId], references: [id])
  subject     Subject     @relation(fields: [subjectId], references: [id])

  @@unique([streamId, subjectId])
}

model Score {
  id        String   @id @default(cuid())
  examScore Float
  caScore   Float
  total     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  subjectId String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
}

model Result {
  id           String   @id @default(cuid())
  totalMarks   Float
  averageScore Float
  grade        String
  classPosition Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

enum Gender {
  MALE
  FEMALE
}